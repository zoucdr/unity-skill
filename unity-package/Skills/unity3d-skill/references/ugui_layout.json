{
  "func": "ugui_layout",
  "description": "UGUI layout tools",
  "args": {
    "type": "object",
    "properties": {
      "action": { "type": "string", "enum": ["set_anchor", "set_pivot", "set_size", "apply_layout", "set_anchored_position"], "description": "Operation type" },
      "target": { "type": "string", "description": "UI element path" },
      "anchor_min": { "type": "array", "items": { "type": "number" }, "description": "Anchor min [x, y]" },
      "anchor_max": { "type": "array", "items": { "type": "number" }, "description": "Anchor max [x, y]" },
      "pivot": { "type": "array", "items": { "type": "number" }, "description": "Pivot [x, y]" },
      "anchored_position": { "type": "array", "items": { "type": "number" }, "description": "Anchored position [x, y]" },
      "size_delta": { "type": "array", "items": { "type": "number" }, "description": "Size delta [width, height]" },
      "layout_group": { "type": "string", "enum": ["horizontal", "vertical", "grid"], "description": "Layout group type" },
      "spacing": { "type": "number", "description": "Spacing between elements" },
      "child_force_expand": { "type": "boolean", "description": "Child force expand" }
    },
    "required": ["action", "target"]
  },
  "actions": [
    { "value": "set_anchor", "description": "Set RectTransform anchor", "requiredParams": ["action", "target", "anchor_min", "anchor_max"] },
    { "value": "set_pivot", "description": "Set RectTransform pivot", "requiredParams": ["action", "target", "pivot"] },
    { "value": "set_size", "description": "Set element size", "requiredParams": ["action", "target", "size_delta"] },
    { "value": "apply_layout", "description": "Apply layout group", "requiredParams": ["action", "target", "layout_group"] },
    { "value": "set_anchored_position", "description": "Set anchored position", "requiredParams": ["action", "target", "anchored_position"] }
  ],
  "response": {
    "success": { "type": "object", "properties": { "success": { "type": "boolean", "const": true }, "data": {} } },
    "failure": { "type": "object", "properties": { "success": { "type": "boolean", "const": false }, "message": { "type": "string" }, "error": { "type": "string" } } }
  }
}
